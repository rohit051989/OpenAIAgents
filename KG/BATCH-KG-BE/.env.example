# Application server
APP_HOST=0.0.0.0
APP_PORT=8001
APP_ENV=development
LOG_LEVEL=INFO

# CORS — comma-separated allowed origins (default: localhost:3000 only)
# ALLOWED_ORIGINS=["http://localhost:3000","https://your-prod-domain.com"]

# MCP Server (default — can be overridden per request)
MCP_SERVER_URL=http://localhost:8100/mcp/sse

# LLM Provider: openai | azure_openai | aws_bedrock | google_gemini
LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Azure OpenAI
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# AWS Bedrock
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0

# Google Gemini
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Auth — set to enable X-API-Key enforcement on all endpoints
# Leave blank for local development (auth is disabled when unset)
API_KEY=

# Sessions
SESSION_TTL_HOURS=24
