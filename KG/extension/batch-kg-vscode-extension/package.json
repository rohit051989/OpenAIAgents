{
  "name": "batch-ig-gap-analyzer",
  "displayName": "Batch IG Gap Analyzer",
  "description": "VS Code extension for analyzing and resolving Spring Batch Information Graph gaps",
  "version": "0.1.0",
  "publisher": "batch-ig",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "*"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "batchIg.openGapAnalyzer",
        "title": "Batch IG: Open Gap Analyzer",
        "category": "Batch IG"
      }
    ],
    "configuration": {
      "title": "Batch IG Gap Analyzer",
      "properties": {
        "batchIg.apiUrl": {
          "type": "string",
          "default": "http://localhost:8000",
          "description": "Base URL of the Batch-IG-Extension-APIs FastAPI service (e.g. http://myserver:8000). Change this setting when the API is deployed on a remote host or different port."
        },
        "batchIg.yamlOutputPath": {
          "type": "string",
          "default": "config/grey_area_resolution.yaml",
          "description": "Output path for generated YAML files"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.80.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "js-yaml": "^4.1.0"
  }
}
