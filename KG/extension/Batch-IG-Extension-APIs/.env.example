# Neo4j connection settings
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_password_here
NEO4J_DATABASE=information_graph

# Path to the application config YAML (relative to the directory you run uvicorn from)
# Default points to the config/ folder inside this project.
CONFIG_PATH=config/app_config.yaml

# API server settings (used when running via main.py directly)
API_HOST=0.0.0.0
API_PORT=8000
